# Copy to .env.local and fill in. NEVER commit real values.
# Anthropic-compatible DashScope gateway.
# ⚠️ BASE-URL SUFFIX DIFFERS BY CONSUMER:
#   • Python AI sidecar (services/ai, the gateway client since Phase 3): the
#     anthropic SDK appends `/v1/messages`, so its ANTHROPIC_BASE_URL must OMIT
#     `/v1` → use `.../apps/anthropic`. (Set in services/ai/.env or the compose
#     `ai` service env; reusing the `/v1` value 404s as `.../v1/v1/messages`.)
#   • Legacy TS AI SDK (`@ai-sdk/anthropic`, pre-Phase-3): appended only
#     `/messages`, so it needed the `/v1`-suffixed value.
# The value below is the Python-sidecar form (no `/v1`).

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_MODEL=qwen3.6-plus
# Triage/draft model split (latency pass 2026-05-31). Both thinking-off.
# Triage = cheap classifier; draft = the visible answer. Override to bench others
# (kimi-k2.5, glm-5, MiniMax-M2.5, qwen3-max-2026-01-23, …).
TRIAGE_MODEL=glm-4.7
DRAFT_MODEL=qwen3.6-plus

# RAG Phase 1 local infra
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
RAG_TOP_K=4
RAG_DEV_SOURCES=true

# Phase 3 Python AI sidecar
AI_SERVICE_URL=http://localhost:8000

# Recruiter UX (M4)
NEXT_PUBLIC_CAL_URL=https://cal.com/your-handle
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username

# Postgres (relational persistence). Local docker-compose default below.
DATABASE_URL=postgres://meclaw:meclaw@localhost:5432/meclaw
