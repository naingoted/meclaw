# Copy to .env.local and fill in. NEVER commit real values.
# Anthropic-compatible DashScope gateway (chat-only; no embeddings).
# NOTE: the AI SDK appends `/messages`, so BASE_URL must end in `/v1`
# (full path becomes `.../apps/anthropic/v1/messages`). Verified M1.

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1
ANTHROPIC_MODEL=qwen3.6-plus

# RAG Phase 1 local infra
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=echo_clone_knowledge
RAG_TOP_K=4
RAG_DEV_SOURCES=true

# Recruiter UX (M4)
NEXT_PUBLIC_CAL_URL=https://cal.com/your-handle
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username

# Python AI sidecar (Phase 3) — local default
AI_SERVICE_URL=http://localhost:8000
