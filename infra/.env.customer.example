# Per-customer env template. provision-customer.sh renders this with generated
# secrets and uploads it to the customer's Dokploy compose app.
# NEVER commit a filled-in copy.

# --- identity ---
CUSTOMER_SLUG=acme
GHCR_OWNER=naingoted
IMAGE_TAG=            # pinned release tag, e.g. v1.0.13-alpha (set by provision script)

# --- LLM gateway (shared key in v1 — see spec D7.2 risk note) ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_MODEL=qwen3.6-plus
TRIAGE_MODEL=glm-4.7
DRAFT_MODEL=qwen3.6-plus

# --- data plane ---
POSTGRES_USER=meclaw
POSTGRES_PASSWORD=
POSTGRES_DB=meclaw
DATABASE_URL=postgres://meclaw:@postgres:5432/meclaw
OLLAMA_BASE_URL=http://meclaw-ollama-shared:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
RAG_TOP_K=3

# --- chat app ---
AI_SERVICE_URL=http://ai:8000
NEXT_PUBLIC_CAL_URL=
NEXT_PUBLIC_GITHUB_URL=
LEAD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RESUME_TOKEN_SECRET=
EMBED_RATE_LIMIT_PER_MIN=60
RATE_LIMIT_MAX_REQUESTS=20
CHAT_GLOBAL_LIMIT_PER_MIN=120
PUBLIC_API_RATE_LIMIT_MAX_REQUESTS=120
PUBLIC_API_GLOBAL_RATE_LIMIT_PER_MIN=600

# --- sidecar cost-control + identity ---
HISTORY_MAX_MESSAGES=10
HISTORY_TOKEN_BUDGET=2000
BOT_OWNER_NAME=
BOT_NAME=
BOT_TAGLINE=
BOT_CONTACT_EMAIL=
BRAND_LOGO_URL=
BRAND_ACCENT=

# --- admin auth ---
AUTH_SECRET=
AUTH_URL=https://${CUSTOMER_SLUG}-admin.leanior.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
