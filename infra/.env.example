# meclaw — single env contract for the whole stack (local dev + prod).
# Copy to infra/.env and fill in. NEVER commit a filled-in .env (it is gitignored).
# On the compose network, hosts are service names (postgres, ollama, ai).

# --- LLM gateway (TS apps + Python sidecar share these) ---
# ANTHROPIC_BASE_URL: the Python sidecar form OMITS a trailing /v1 (the anthropic
# SDK appends /v1/messages itself; reusing a /v1 value 404s as /v1/v1/messages).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=qwen3.6-plus
TRIAGE_MODEL=glm-4.7
DRAFT_MODEL=qwen3.6-plus

# --- data plane ---
DATABASE_URL=postgres://meclaw:meclaw@postgres:5432/meclaw
POSTGRES_USER=meclaw
POSTGRES_PASSWORD=meclaw
POSTGRES_DB=meclaw
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
RAG_TOP_K=4

# --- chat app ---
AI_SERVICE_URL=http://ai:8000
NEXT_PUBLIC_CAL_URL=
NEXT_PUBLIC_GITHUB_URL=
# Optional: owner notification webhook for captured leads (Slack/Discord-style).
# Leads still persist if unset; only the ping is skipped.
LEAD_WEBHOOK_URL=

# Embed widget: signs the HMAC resume tokens that let anonymous browsers
# hydrate their prior conversation on return. Rotate if ever leaked.
# openssl rand -hex 32
RESUME_TOKEN_SECRET=
# Default per-embed-client rate limit (per minute). Per-client overrides
# in the admin UI take precedence.
EMBED_RATE_LIMIT_PER_MIN=60
# Public chat POST limits. Per-IP plus stack-wide ceiling.
RATE_LIMIT_MAX_REQUESTS=20
CHAT_GLOBAL_LIMIT_PER_MIN=120
# Cheap public GET route limits (/api/embed-config, /api/chat/history,
# /api/config-version, and middleware's embed-client lookup).
PUBLIC_API_RATE_LIMIT_MAX_REQUESTS=120
PUBLIC_API_GLOBAL_RATE_LIMIT_PER_MIN=600
# Chat app's own browser origin — used to distinguish cross-origin API calls
# from same-origin iframe embed requests. Dev: http://localhost:3000
CHAT_APP_ORIGIN=http://localhost:3000

# --- admin auth (Auth.js) ---
# AUTH_SECRET: openssl rand -hex 32
# ADMIN_PASSWORD_HASH: pnpm --filter @meclaw/admin gen:admin-hash <password>
AUTH_SECRET=
AUTH_URL=https://admin.example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# --- @meclaw/mcp (read-only MCP server) ---
MCP_DATABASE_URL=
MCP_AUTH_TOKEN=
MCP_ALLOW_PII=false

# --- prod deploy (compose interpolation) ---
DOMAIN=example.com
GHCR_OWNER=
IMAGE_TAG=latest
