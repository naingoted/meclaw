# meclaw production env — copy to /opt/meclaw/infra/.env on the VPS and fill in.
# NEVER commit the filled-in file. Hosts use compose service names.

# --- LLM gateway ---
# Rotate the key that was exposed in chat. Sidecar base-url OMITS /v1.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_MODEL=qwen3.6-plus
TRIAGE_MODEL=glm-4.7
DRAFT_MODEL=qwen3.6-plus

# --- data plane (service-name hosts on the compose network) ---
# Set POSTGRES_PASSWORD and mirror it in DATABASE_URL.
POSTGRES_USER=meclaw
POSTGRES_PASSWORD=
POSTGRES_DB=meclaw
DATABASE_URL=postgres://meclaw:@postgres:5432/meclaw
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
RAG_TOP_K=3

# --- branding / persona ---
# ⚠️ Unset → falls back to the ORIGINAL AUTHOR's identity (Thet / meclaw /
# naingoted@gmail.com). Set ALL of these for any non-author deploy.
BOT_NAME=meclaw
BOT_OWNER_NAME=Thet
BOT_TAGLINE=
BOT_CONTACT_EMAIL=
BRAND_ACCENT=
BRAND_LOGO_URL=

# --- chat app ---
AI_SERVICE_URL=http://ai:8000
NEXT_PUBLIC_CAL_URL=https://cal.com/your-handle
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username
# Chat app's own public origin — distinguishes cross-origin API calls from
# same-origin iframe embed requests. Set to the prod chat URL.
CHAT_APP_ORIGIN=https://meclaw.yourdomain.com

# Owner lead alerts on captured contact info. ALL optional — each channel no-ops
# SILENTLY when unset (never throws; leads still persist). See docs/ai/config.md.
LEAD_WEBHOOK_URL=
# Telegram: BOTH required together or the telegram branch is skipped silently.
# Token from @BotFather; chat id via getUpdates. Validate: /getMe + sendMessage.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Embed widget: signs the HMAC resume tokens that let anonymous browsers
# hydrate their prior conversation on return. Rotate if ever leaked.
# openssl rand -hex 32
RESUME_TOKEN_SECRET=
EMBED_RATE_LIMIT_PER_MIN=60

# --- admin auth ---
# AUTH_SECRET: openssl rand -hex 32
# ADMIN_PASSWORD_HASH: pnpm --filter @meclaw/admin gen:admin-hash <password>
AUTH_SECRET=
# Must equal https://<ADMIN_DOMAIN> below (the host Caddy serves the admin app on).
AUTH_URL=https://meclaw-admin.yourdomain.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# --- research agent (Spec C, optional) ---
# Web search key. Absent → web subtasks degrade (not fatal). Other RESEARCH_*/
# FETCH_* knobs use in-code defaults — see docs/ai/config.md.
TAVILY_API_KEY=

# --- @meclaw/mcp (read-only MCP server) ---
MCP_DATABASE_URL=
MCP_AUTH_TOKEN=
MCP_ALLOW_PII=false

# --- deploy / compose interpolation ---
# DOMAIN = chat host (Caddy apex), ADMIN_DOMAIN = admin host. Both must have
# A records pointing at this box; Caddy auto-issues Let's Encrypt certs for them.
DOMAIN=meclaw.yourdomain.com
ADMIN_DOMAIN=meclaw-admin.yourdomain.com
GHCR_OWNER=your-github-username-lowercase
IMAGE_TAG=latest
