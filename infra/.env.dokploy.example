# meclaw env for the Dokploy deploy. Set these in the Dokploy app's Environment
# tab (Dokploy writes the .env that docker-compose.dokploy.yml reads).
# NEVER commit the filled-in file. Service-name hosts on the compose network.

# --- LLM gateway ---
# Rotate any key ever pasted into chat/logs. Sidecar base-url OMITS /v1.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_MODEL=qwen3.6-plus
TRIAGE_MODEL=glm-4.7
DRAFT_MODEL=qwen3.6-plus

# --- data plane (service-name hosts on the internal compose network) ---
# Set POSTGRES_PASSWORD and mirror it in DATABASE_URL.
POSTGRES_USER=meclaw
POSTGRES_PASSWORD=
POSTGRES_DB=meclaw
DATABASE_URL=postgres://meclaw:@postgres:5432/meclaw
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
RAG_TOP_K=4

# --- chat app ---
AI_SERVICE_URL=http://ai:8000
NEXT_PUBLIC_CAL_URL=https://cal.com/your-handle
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username
LEAD_WEBHOOK_URL=

# Telegram lead notify (D6): bot token from @BotFather; chat id of the owner's
# chat/group with the bot. Both must be set or the channel is skipped.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Embed widget: signs the HMAC resume tokens that let anonymous browsers
# hydrate their prior conversation on return. Rotate if ever leaked.
# openssl rand -hex 32
RESUME_TOKEN_SECRET=
EMBED_RATE_LIMIT_PER_MIN=60

# --- admin auth ---
# AUTH_SECRET: openssl rand -hex 32
# ADMIN_PASSWORD_HASH: pnpm --filter @meclaw/admin gen:admin-hash <password>
AUTH_SECRET=
AUTH_URL=https://meclaw-admin.leanior.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# --- @meclaw/mcp (read-only MCP server) ---
MCP_DATABASE_URL=
MCP_AUTH_TOKEN=
MCP_ALLOW_PII=false

# --- deploy / compose interpolation ---
# Domains are hardcoded in docker-compose.dokploy.yml (Traefik labels):
#   meclaw.leanior.com -> chat, meclaw-admin.leanior.com -> admin
# GHCR_OWNER: lowercase GitHub owner that hosts the meclaw-* packages.
GHCR_OWNER=naingoted
IMAGE_TAG=latest
