# Production .env template — copy to /opt/meclaw/.env on the VPS and fill in.
# NEVER commit the filled-in file. Hosts use compose service names.

# --- Chat gateway (rotate the key that was exposed in chat) ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1
ANTHROPIC_MODEL=qwen3.6-plus

# --- RAG infra (service-name hosts on the compose network) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=meclaw_knowledge
RAG_TOP_K=4
RAG_DEV_SOURCES=false

# --- Python sidecar (Phase 3) ---
AI_SERVICE_URL=http://ai:8000

# --- Recruiter UX ---
NEXT_PUBLIC_CAL_URL=https://cal.com/your-handle
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username

# --- Deploy / compose interpolation ---
GHCR_OWNER=your-github-username-lowercase
IMAGE_TAG=latest
DOMAIN=yourdomain.com
