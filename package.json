{
  "name": "meclaw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify": "turbo run lint typecheck build",
    "db:generate": "pnpm --filter @meclaw/core db:generate",
    "db:migrate": "pnpm --filter @meclaw/core db:migrate",
    "ingest": "pnpm --filter @meclaw/rag ingest",
    "dev:full": "docker compose -f infra/docker-compose.yml up --build",
    "services": "docker compose -f infra/docker-compose.yml up -d ollama postgres",
    "dev:ai": "cd services/ai && uv run --env-file .env uvicorn app.main:app --port 8000 --reload",
    "fallow": "fallow",
    "fallow:audit": "fallow audit",
    "coverage": "turbo run test --force -- --coverage && node scripts/merge-coverage.mjs",
    "fallow:cov": "pnpm coverage && fallow health --coverage coverage/coverage-final.json",
    "fallow:cov:report": "pnpm coverage && fallow health --coverage coverage/coverage-final.json --report-only",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-istanbul": "^4.1.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "fallow": "^2.87.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4",
    "turbo": "^2",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
