#!/bin/sh
# Fast staged-only gate. Whole-repo lint/typecheck/test run at pre-push; audit/semgrep in CI.
# Never bypass with --no-verify — fix the finding.

# 1. cheap content guards (keys, env, big files, conflict markers)
./scripts/guard-staged.sh || exit 1

# 2. format/organize + secret scan on staged files
lint-staged || exit 1

# 3. fallow gate (hard-fail if missing so it can't be silently skipped).
# Use the default incremental gate so inherited hotspots in touched legacy files
# do not block commits unless the changeset introduces the finding.
if ! command -v fallow >/dev/null 2>&1; then
  echo "pre-commit: 'fallow' not found on PATH. Run 'pnpm install' (devDependency)." >&2
  exit 1
fi
UPSTREAM="$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)"
if [ -n "$UPSTREAM" ]; then
  BASE="$(git merge-base "$UPSTREAM" HEAD 2>/dev/null || echo "$UPSTREAM")"
else
  BASE="main"
fi
fallow audit --base "$BASE" --quiet --gate-marker pre-commit || exit 1
