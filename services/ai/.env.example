# Python AI sidecar — host-dev env (`pnpm dev:ai` loads this via `uv --env-file .env`).
# Copy to services/ai/.env and fill ANTHROPIC_API_KEY. NEVER commit the filled file (gitignored).
#
# Only needed for HOST dev. With `pnpm dev:full` the sidecar runs in Docker and
# reads infra/.env instead — you do not need this file.
#
# Hosts below are localhost (host dev). In Docker they would be service names
# (postgres, ollama) — that variant lives in infra/.env.example.

# --- LLM gateway ---
# ANTHROPIC_BASE_URL: the Python form OMITS a trailing /v1 (the anthropic SDK
# appends /v1/messages itself; a /v1 value 404s as /v1/v1/messages).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_MODEL=qwen3.6-plus
TRIAGE_MODEL=glm-4.7
DRAFT_MODEL=qwen3.6-plus

# --- data plane (localhost; started by `pnpm services`) ---
DATABASE_URL=postgres://meclaw:meclaw@localhost:5432/meclaw
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- retrieval tuning (optional; sane defaults in code) ---
RAG_TOP_K=3

# History cap (caching lever 1): rolling window + estimated-token budget for
# what the LLM sees per request. Bounds per-request spend on long chats.
HISTORY_MAX_MESSAGES=10
HISTORY_TOKEN_BUDGET=2000

# --- tool defaults surfaced in chat (optional) ---
NEXT_PUBLIC_CAL_URL=
NEXT_PUBLIC_GITHUB_URL=
